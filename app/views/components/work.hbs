{{#if resume.work.length}}
<div class="container work-container">
  {{> title value="Experience"}}

  {{#each resume.work}}
  <section class="item">
    {{> section-header name=(coalesce this.name this.company) }}

    {{#if position}}
      <h4>{{position}}</h4>
    {{/if}}

    {{#if summary}}
      <p class="summary">{{{markdown summary}}}</p>
    {{/if}}

    {{#if highlights.length}}
      <ul>
        {{#each highlights}}
        <li>{{{markdown .}}}</li>
        {{/each}}
      </ul>
    {{/if}}
  </section>
  {{/each}}
</div>
{{/if}}
